---
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialIcons from "../components/SocialIcons.astro";
import { profile, site } from "../data/site";

const facts: { label: string; value: string }[] = [
  { label: "Name", value: "Trista Pan (Juan Pan)" },
  { label: "City", value: "Beijing, China" },
  { label: "Title", value: "AI Engineer @ Tetrate" },
  { label: "Email", value: "hannkenn0@gmail.com" },
];

const community = [
  "Apache Member & Incubator Mentor",
  "Apache ShardingSphere PMC",
  "Apache brpc / AGE / HugeGraph Mentor",
  "AWS Data Hero",
  "Tencent Cloud TVP",
  "Mentor, China Mulan Open Source Community",
];

const education = [
  {
    degree: "Master's degree",
    detail: "Visual Pattern Retrieval & Cloud Computing · Dalian Maritime University",
    period: "Sep 2014 – Jun 2016",
  },
  {
    degree: "Bachelor's degree",
    detail: "Software Development · Hebei Normal University",
    period: "Sep 2010 – Jun 2014",
  },
];

const career = [
  {
    role: "AI Engineer",
    org: "Tetrate",
    period: "",
    points: [
      "Building AI systems and infrastructure.",
    ],
  },
  {
    role: "AI Product Director",
    org: "ByteDance",
    period: "May 2025 – Nov 2026",
    points: [
      "Focused on big data and AI products.",
    ],
  },
  {
    role: "Co-Founder & CTO",
    org: "SphereEx",
    period: "2021 – 2025",
    points: [
      "Co-founded SphereEx; led the distributed database & middleware ecosystem and open-source community.",
      "AWS Data Hero; Apache ShardingSphere PMC.",
    ],
  },
  {
    role: "Senior Distributed Database Engineer",
    org: "JD.com",
    period: "Jan 2018 – Apr 2021",
    points: [
      "Led R&D of the distributed cloud database platform and distributed transaction engine.",
      "Apache ShardingSphere maintainer; ASF Incubator Mentor & Member.",
    ],
  },
  {
    role: "Senior DBA Engineer",
    org: "JD.com",
    period: "Jan 2016 – Jan 2018",
    points: [
      "Operated large-scale MySQL/Oracle database clusters.",
      "Architected the database automation management platform (Python, DevOps).",
    ],
  },
];

const awards = [
  "Globee Awards — Chief Technology Officer of the Year (2022)",
  "CSDN — IT Leading Personality of the Year (2021)",
  "CAICT OSCAR — Top Open Source Pioneer (2021)",
  "China Open Source Pioneer (2020)",
  "First female Apache Member in China",
];

const publications = [
  {
    title: "A Definitive Guide to Apache ShardingSphere",
    note: "Book · Packt, 2022 · First author",
    url: "https://www.amazon.com/Definitive-Guide-Apache-ShardingSphere-distributed/dp/1803239425",
  },
  {
    title: "Apache ShardingSphere: A Holistic and Pluggable Platform for Data Sharding",
    note: "Paper · ICDE 2022",
    url: "https://ieeexplore.ieee.org/document/9835604",
  },
];
---

<BaseLayout title="About" description="About Trista Pan — SphereEx Co-Founder & CTO, Apache Member, AWS Data Hero.">
  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <!-- Intro -->
    <div class="flex flex-col items-start gap-6 sm:flex-row sm:items-center" data-reveal>
      <div class="relative isolate shrink-0">
        <div
          class="absolute -inset-2 -z-10 rounded-full bg-gradient-to-tr from-accent/40 via-violet-500/30 to-sky-500/40 opacity-70 blur-xl"
          aria-hidden="true"
        >
        </div>
        <img
          src={site.avatar}
          alt={profile.name}
          width="96"
          height="96"
          class="h-24 w-24 rounded-full object-cover shadow-lg shadow-black/10 ring-1 ring-white/60 dark:ring-white/10"
        />
      </div>
      <div>
        <h1 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100">
          {profile.name}
        </h1>
        <p class="mt-1 font-medium text-accent">{profile.role}</p>
        <div class="mt-3"><SocialIcons /></div>
      </div>
    </div>

    <p class="mt-8 leading-relaxed text-neutral-700 dark:text-neutral-300">
      AI Engineer at Tetrate, ex AI Product Director at ByteDance, former Co-Founder of SphereEx,
      Apache Member & Incubator Mentor, and AWS Data Hero. Her expertise is in big data and AI. Due to her rich experience in
      open source, she was elected an OSCAR Top Open Source Pioneer. In 2022, her paper
      <em>“Apache ShardingSphere: A Holistic and Pluggable Platform for Data Sharding”</em> was
      published at ICDE. As the first author, she wrote a book titled
      <em>A Definitive Guide to Apache ShardingSphere</em>, published by Packt in 2022.
    </p>

    <!-- Quick facts -->
    <dl class="mt-10 grid gap-x-8 gap-y-3 sm:grid-cols-2">
      {
        facts.map((f) => (
          <div class="flex gap-2 text-sm">
            <dt class="w-16 shrink-0 font-medium text-neutral-500 dark:text-neutral-400">{f.label}</dt>
            <dd class="text-neutral-800 dark:text-neutral-200">{f.value}</dd>
          </div>
        ))
      }
    </dl>

    <!-- Community roles -->
    <section data-reveal class="mt-12">
      <h2 class="text-lg font-semibold tracking-tight text-neutral-900 dark:text-neutral-100">Community</h2>
      <ul class="mt-3 flex flex-wrap gap-2">
        {
          community.map((c) => (
            <li class="rounded-full bg-neutral-100 px-3 py-1 text-sm text-neutral-700 dark:bg-neutral-800 dark:text-neutral-200">
              {c}
            </li>
          ))
        }
      </ul>
    </section>

    <!-- Career -->
    <section data-reveal class="mt-12">
      <h2 class="text-lg font-semibold tracking-tight text-neutral-900 dark:text-neutral-100">Career</h2>
      <div class="mt-4 space-y-6">
        {
          career.map((job) => (
            <div class="border-l-2 border-neutral-200 pl-4 dark:border-neutral-800">
              <div class="flex flex-wrap items-baseline justify-between gap-x-3">
                <h3 class="font-medium text-neutral-900 dark:text-neutral-100">
                  {job.role} · <span class="text-neutral-600 dark:text-neutral-300">{job.org}</span>
                </h3>
                <span class="text-sm text-neutral-400">{job.period}</span>
              </div>
              <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-neutral-600 dark:text-neutral-400">
                {job.points.map((p) => <li>{p}</li>)}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Education -->
    <section data-reveal class="mt-12">
      <h2 class="text-lg font-semibold tracking-tight text-neutral-900 dark:text-neutral-100">Education</h2>
      <div class="mt-4 space-y-4">
        {
          education.map((e) => (
            <div class="flex flex-wrap items-baseline justify-between gap-x-3">
              <div>
                <h3 class="font-medium text-neutral-900 dark:text-neutral-100">{e.degree}</h3>
                <p class="text-sm text-neutral-600 dark:text-neutral-400">{e.detail}</p>
              </div>
              <span class="text-sm text-neutral-400">{e.period}</span>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Publications -->
    <section data-reveal class="mt-12">
      <h2 class="text-lg font-semibold tracking-tight text-neutral-900 dark:text-neutral-100">Publications</h2>
      <div class="mt-4 space-y-3">
        {
          publications.map((p) => (
            <a
              href={p.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group card-lift block rounded-xl border border-neutral-200/80 bg-white/60 p-4 backdrop-blur-sm hover:border-accent/50 hover:bg-white dark:border-neutral-800/80 dark:bg-neutral-900/40 dark:hover:bg-neutral-900/70"
            >
              <h3 class="font-medium text-neutral-900 group-hover:text-accent dark:text-neutral-100">{p.title}</h3>
              <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">{p.note}</p>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Awards -->
    <section data-reveal class="mt-12">
      <h2 class="text-lg font-semibold tracking-tight text-neutral-900 dark:text-neutral-100">Awards & Recognition</h2>
      <ul class="mt-4 space-y-2">
        {
          awards.map((a) => (
            <li class="flex items-start gap-2 text-sm text-neutral-700 dark:text-neutral-300">
              <span class="mt-1 text-accent">&#9679;</span>
              <span>{a}</span>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</BaseLayout>
