---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
  );
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const fmt = (d: string) =>
  new Date(d).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="mx-auto max-w-content px-4 py-16 sm:px-6">
    <a
      href="/blog"
      class="text-sm font-medium text-neutral-500 transition-colors hover:text-accent dark:text-neutral-400"
    >
      &larr; All posts
    </a>

    <header class="mt-6 mb-8">
      <time class="text-sm tabular-nums text-neutral-400 dark:text-neutral-500">
        {fmt(post.data.date)}
      </time>
      <h1 class="mt-1 text-3xl font-bold tracking-tight text-neutral-900 sm:text-4xl dark:text-neutral-100">
        {post.data.title}
      </h1>
      {
        post.data.description && (
          <p class="mt-3 text-lg text-neutral-600 dark:text-neutral-300">{post.data.description}</p>
        )
      }
    </header>

    <div
      class="prose prose-neutral max-w-none dark:prose-invert prose-a:text-accent prose-a:no-underline hover:prose-a:underline prose-pre:bg-neutral-900 prose-pre:text-neutral-100"
    >
      <Content />
    </div>
  </article>
</BaseLayout>
